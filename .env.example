# =============================================================================
# VIBE3 VIDEO PLATFORM — Environment Variables Template
# Copy this file to .env.local (apps/web) and .env (apps/worker)
# NEVER commit .env.local or .env files to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — Database, Auth, Realtime
# https://app.supabase.com → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side only
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Direct DB URL (for Drizzle migrations)
DATABASE_URL=postgresql://postgres:password@localhost:5433/vibe3
# Pooled URL (for runtime queries)
DATABASE_URL_POOLED=postgresql://postgres:password@localhost:5433/vibe3?pgbouncer=true

# -----------------------------------------------------------------------------
# CLOUDFLARE R2 / MINIO — Object Storage
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=admin
R2_SECRET_ACCESS_KEY=password123
R2_BUCKET_NAME=vibe3-videos

# Public URL for the R2 bucket
R2_PUBLIC_URL=http://localhost:9000/vibe3-videos

# Endpoint (Local MinIO: http://localhost:9000 | R2: https://...r2.cloudflarestorage.com)
R2_ENDPOINT=http://localhost:9000

# -----------------------------------------------------------------------------
# REDIS — Job Queue (BullMQ)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# WORKER — Video Processing Service
# -----------------------------------------------------------------------------
WORKER_SECRET=replace_with_strong_random_secret_min_32_chars
WORKER_URL=http://localhost:3001
FFMPEG_PATH=
WORKER_CONCURRENCY=2
WORKER_TMP_DIR=C:/temp/vibe3

# -----------------------------------------------------------------------------
# NEXT.JS APP
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAX_UPLOAD_SIZE=10737418240
PRESIGNED_URL_EXPIRY=900
