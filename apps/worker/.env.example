# Vibe3 Worker — Video Processing
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5433/vibe3

R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=admin
R2_SECRET_ACCESS_KEY=password123
R2_BUCKET_NAME=vibe3-videos
