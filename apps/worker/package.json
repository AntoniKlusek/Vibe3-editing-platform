{
  "name": "@vibe3/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Video processing worker — FFmpeg HLS transcoding via BullMQ",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vibe3/db": "workspace:*",
    "@vibe3/queue": "workspace:*",
    "@aws-sdk/client-s3": "^3.726.1",
    "@aws-sdk/s3-request-presigner": "^3.726.1",
    "bullmq": "^5.34.8",
    "dotenv": "^16.4.7",
    "ioredis": "5.5.0",
    "@supabase/supabase-js": "^2.48.1",
    "tsx": "^4.19.2",
    "drizzle-orm": "^0.39.3"
  },
  "devDependencies": {
    "@vibe3/config": "workspace:*",
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  }
}
